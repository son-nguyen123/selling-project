# Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous / public key (Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Supabase service-role secret key (Settings → API → service_role secret)
# NEVER expose this in client-side code or commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Your public site URL (used for auth email redirect links).
# Set this to your production domain on Vercel, or http://localhost:3000 locally.
# Must match the "Site URL" configured in Supabase Dashboard → Authentication → URL Configuration.
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Gmail SMTP credentials for sending order-confirmation emails with Nodemailer.
# 1. Enable 2-Step Verification on your Google account.
# 2. Go to https://myaccount.google.com/apppasswords and create an App Password.
# 3. Use that 16-character App Password as GMAIL_PASS (NOT your normal password).
GMAIL_USER=you@gmail.com
GMAIL_PASS=xxxx-xxxx-xxxx-xxxx
